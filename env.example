# Скопируйте в .env.local для локальной разработки или задайте в Vercel → Settings → Environment Variables

# Логин продавца без @ (откроется https://t.me/<username>?text=...)
VITE_SELLER_USERNAME=vvewrix

# Сколько сомони за 1 российский рубль (подстройте под рынок)
VITE_RUB_TO_TJS=0.122

# Наценка % по «ступеням» от базовой суммы в сомони (см. src/pricing.ts)
VITE_MARKUP_LOW_PCT=16
VITE_MARKUP_MID_PCT=13
VITE_MARKUP_HIGH_PCT=10

# Доп. фиксированная надбавка в сомони (ступени в pricing.ts). Укажите 0 чтобы отключить только её.
# VITE_FLAT_PROFIT_TJS=0
