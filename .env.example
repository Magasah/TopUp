# ---- Telegram (server-only; never commit real values) ----
TELEGRAM_BOT_TOKEN=000000000:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA

# Admin chat / group id (numeric) — orders & reviews moderation
# https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_ADMIN_CHAT_ID=000000000

NEXT_PUBLIC_APP_NAME=TopUp.TJ

# ---- Python TopUpTJ_Bot order ingest (optional; enables DB + inline admin buttons) ----
# Public URL of your bot machine where aiohttp listens (use HTTPS in production).
ORDER_INGEST_URL=http://127.0.0.1:8090/internal/orders
# Same value as INTERNAL_API_SECRET in TopUpTJ_Bot/.env
INTERNAL_API_SECRET=

# ---- Requisites (optional overrides; defaults are in lib/wallets.ts) ----
NEXT_PUBLIC_WALLET_DC=+992888788181
NEXT_PUBLIC_WALLET_ALIF=+992888788181
NEXT_PUBLIC_WALLET_MASTERCARD=5413525250170749
NEXT_PUBLIC_WALLET_MILLI=9762000106186207
